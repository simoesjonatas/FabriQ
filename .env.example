# Copie este arquivo para .env e ajuste os valores.
# O arquivo .env NUNCA deve ser versionado no git.

# Gere uma chave nova para produção:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=troque-esta-chave

# Ambiente: config.settings.local ou config.settings.production
DJANGO_SETTINGS_MODULE=config.settings.local

# Banco de dados:
# - Desenvolvimento: deixe comentado para usar SQLite (db.sqlite3)
# - PostgreSQL local (docker compose up -d):
#   DATABASE_URL=postgres://fabriq:fabriq@localhost:5433/fabriq?connect_timeout=5
# - Produção: obrigatório apontar para o PostgreSQL do servidor

# Somente produção:
# DJANGO_ALLOWED_HOSTS=fabriq.simoesti.com.br
# DJANGO_CSRF_TRUSTED_ORIGINS=https://fabriq.simoesti.com.br
# DJANGO_SECURE_SSL_REDIRECT=True
