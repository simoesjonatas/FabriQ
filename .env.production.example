# Copie para .env.production no servidor e ajuste os segredos.
# Nao versione .env.production.

DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=troque-esta-chave-em-producao

# Entradas de ALLOWED_HOSTS nunca levam porta: o Django compara o host sem ela.
DJANGO_ALLOWED_HOSTS=fabriq.simoesti.com.br
DJANGO_CSRF_TRUSTED_ORIGINS=https://fabriq.simoesti.com.br
# Para simular producao localmente (acesso via http), acrescente aos dois acima
# localhost,127.0.0.1,<ip-da-maquina> / http://localhost:8000 etc. e mude os
# tres abaixo para False (cookies "Secure" nao funcionam via http fora de localhost).
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SERVE_MEDIA=True
DJANGO_DEFAULT_FROM_EMAIL=FabriQ <nao-responda@simoesti.com.br>

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=fabriq
POSTGRES_USER=fabriq
POSTGRES_PASSWORD=troque-esta-senha-do-postgres

FABRIQ_DOMAIN=fabriq.simoesti.com.br
FABRIQ_WEB_PORT=8000
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
